---
// Layer 2 — long-form article / case study. Cover + meta header, then the
// rendered markdown body (passed as a slot) in brand prose. Content-agnostic:
// it only takes typed props, never hardcoded copy.
import type { ImageMetadata } from "astro";
import BaseLayout from "./BaseLayout.astro";
import Section from "@/components/ui/Section.astro";
import Prose from "@/components/ui/Prose.astro";
import Picture from "@/components/ui/Picture.astro";
import { SITE_URL } from "@/config/site";
import { getLangFromUrl, useTranslations, localizePath } from "@/i18n/utils";
import formatDate from "@/utils/formatDate";

interface Props {
	title: string;
	description?: string;
	publishedAt: Date;
	tags?: string[];
	cover?: ImageMetadata;
	coverAlt?: string;
}

const {
	title,
	description,
	publishedAt,
	tags = [],
	cover,
	coverAlt,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Per-page OpenGraph: use the cover as the share image when present.
const og = cover
	? {
			title,
			type: "article",
			description: description ?? "",
			image: new URL(cover.src, SITE_URL).href,
			alt: coverAlt ?? title,
		}
	: undefined;
---

<BaseLayout title={title} description={description} og={og}>
	<article class="py-6 lg:py-10">
		<Section width="prose" class="flex flex-col gap-4">
			<a
				href={localizePath("/blog", lang)}
				class="text-colorfor-text-secondary hover:text-colorfor-accent-primary self-start text-sm transition-colors"
			>
				← {t("blog.back")}
			</a>

			<div class="flex flex-col gap-3">
				<h1>{title}</h1>
				<div class="text-colorfor-text-secondary flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
					<time datetime={publishedAt.toISOString()}>
						{formatDate(publishedAt)}
					</time>
					{
						tags.length > 0 && (
							<ul class="flex flex-wrap gap-2">
								{tags.map((tag) => (
									<li class="border-colorfor-accent-primary text-colorfor-accent-primary border px-2 py-0.5 text-xs tracking-wide uppercase">
										{tag}
									</li>
								))}
							</ul>
						)
					}
				</div>
			</div>
		</Section>

		{
			cover && (
				<Section width="content" class="mt-8">
					<Picture
						src={cover}
						alt={coverAlt ?? title}
						loading="eager"
						class="mx-auto max-h-[70vh] w-auto object-contain"
					/>
				</Section>
			)
		}

		<Section width="prose" class="mt-10">
			<Prose>
				<slot />
			</Prose>
		</Section>
	</article>
</BaseLayout>
