---
// Contact page — a short, warm message and large links to the social pages.
// No form: the brand's contact happens on Facebook & Instagram.
import { getEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import Section from "@/components/ui/Section.astro";
import presentation from "@/data/presentation";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { pick, paragraphs } from "@/utils/text";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const contact = (await getEntry("pages", "contact"))!.data;
const heading = pick(contact.heading, lang);
const text = paragraphs(pick(contact.text, lang));
---

<BaseLayout title={heading || t("nav.contact")}>
  <Section width="prose" class="py-16 text-center lg:py-24">
    {heading && <h1 class="mb-6">{heading}</h1>}

    <div class="flex flex-col gap-4">
      {text.map((p) => <p class="text-xl">{p}</p>)}
    </div>

    <ul class="mt-12 flex flex-wrap justify-center gap-6">
      {
        presentation.socials.map((social) => (
          <li>
            <a
              href={social.link}
              rel="noreferrer"
              target="_blank"
              class="bg-colorfor-bg-card text-colorfor-text-body-inverse flex items-center gap-3 rounded-(--roundedness-card) px-7 py-4 text-2xl transition hover:opacity-80"
            >
              <span class="[&_svg]:size-7" set:html={social.icon} />
              {social.label}
            </a>
          </li>
        ))
      }
    </ul>
  </Section>
</BaseLayout>
